<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>NEXO Interface V0</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <% final_decision = case @state[:event_type].to_s
      when 'system_event:approved' then 'Approved'
      when 'system_event:flagged' then 'Flagged For Review'
      when 'system_event:blocked' then 'Blocked'
      else 'No Decision Observed'
    end %>

    <main class="shell">
      <header class="hero">
        <p class="eyebrow">NEXO / Interface V0</p>
        <h1>Core-first, edges-visible operator surface</h1>
        <p class="subline">
          Final decision and auditability stay at the center. Edge diagnostics are visible as secondary context only.
        </p>
        <div class="hero-tags">
          <span class="tag tag-core">Primary / Authoritative operator view</span>
          <span class="tag tag-context">Secondary / Diagnostic context only</span>
        </div>
      </header>

      <section class="toolbar" aria-label="status controls">
        <button id="refresh-btn" type="button">Refresh now</button>
        <span class="muted">Auto polling every 3s</span>
        <span class="muted" id="source-mode">mode: <%= @surface_mode_label %></span>
        <span class="muted">source_type: <span id="source-type"><%= @source_type %></span></span>
        <span class="muted">last updated: <span id="last-updated"><%= Time.now.utc.strftime('%Y-%m-%d %H:%M:%S UTC') %></span></span>
      </section>

      <section class="zone zone-core" aria-label="Primary/Core Surface">
        <div class="zone-head">
          <h2>Primary/Core Surface</h2>
          <p>Center closed on deterministic evaluate, final decision, trace, audit trail, and offline verification path.</p>
        </div>

        <div class="core-grid">
          <article class="panel panel-core">
            <h3>Evaluate (Deterministic)</h3>
            <p class="value" id="core-system-status"><%= @state[:system_status] %></p>
            <p class="helper">Input execution belongs to the deterministic core. This screen reflects the current evaluated state.</p>
          </article>

          <article class="panel panel-decision">
            <h3>Final Decision (Primary)</h3>
            <p class="value value-decision" id="core-final-decision"><%= final_decision %></p>
            <p class="helper">Decision is local and auditable for this node context.</p>
          </article>

          <article class="panel">
            <h3>Trace</h3>
            <dl class="kv">
              <dt>kind</dt><dd id="trace-kind"><%= @state[:latest_change_kind] || 'n/a' %></dd>
              <dt>summary</dt><dd id="trace-summary"><%= @state[:latest_change_summary] || 'n/a' %></dd>
              <dt>origin</dt><dd id="trace-origin"><%= @state[:latest_change_origin] || 'n/a' %></dd>
              <dt>timestamp</dt><dd id="trace-timestamp"><%= @state[:latest_change_timestamp] || 'n/a' %></dd>
            </dl>
          </article>

          <article class="panel">
            <h3>Audit Trail</h3>
            <dl class="kv">
              <dt>last_event_hash</dt><dd id="audit-last-event-hash"><%= @state[:last_event_hash] || 'n/a' %></dd>
              <dt>recent_event_hash</dt><dd id="audit-recent-event-hash"><%= @state[:recent_event_hash] || 'n/a' %></dd>
              <dt>event_type</dt><dd id="audit-event-type"><%= @state[:event_type] || 'n/a' %></dd>
              <dt>event_origin</dt><dd id="audit-event-origin"><%= @state[:event_origin] || 'n/a' %></dd>
              <dt>event_channel</dt><dd id="audit-event-channel"><%= @state[:event_channel] || 'n/a' %></dd>
              <dt>event_timestamp</dt><dd id="audit-event-timestamp"><%= @state[:event_timestamp] || 'n/a' %></dd>
            </dl>
          </article>

          <article class="panel panel-zig">
            <h3>Verify Offline (Zig)</h3>
            <p class="value">Offline verification path available.</p>
            <p class="helper">
              Use Zig verification tooling as an audit check path. It is a verification capability, not new runtime authority.
            </p>
          </article>
        </div>
      </section>

      <section class="zone zone-context" aria-label="Secondary/Context Surface">
        <div class="zone-head">
          <h2>Secondary/Context Surface</h2>
          <p>Context supports operator understanding but does not override <code>final_decision</code>.</p>
        </div>

        <div class="context-grid">
          <article class="panel panel-context">
            <h3>Witness / Diagnostics</h3>
            <span class="badge">Diagnostic only</span>
            <dl class="kv">
              <dt>latest_change_source</dt><dd id="ctx-latest-change-source"><%= @state[:latest_change_source] || 'n/a' %></dd>
              <dt>write_status</dt><dd id="ctx-write-status"><%= @state[:write_status] || 'n/a' %></dd>
              <dt>relay_status</dt><dd id="ctx-relay-status"><%= @state[:relay_status] || 'n/a' %></dd>
            </dl>
          </article>

          <article class="panel panel-context">
            <h3>Julia Observer</h3>
            <span class="badge">Secondary signal</span>
            <dl class="kv">
              <dt>observation</dt><dd id="ctx-julia-summary"><%= @state[:julia_observation_summary] || 'not available' %></dd>
              <dt>flow_intensity</dt><dd id="ctx-julia-flow"><%= @state[:julia_observation_flow_intensity] || 'n/a' %></dd>
              <dt>regime_hint</dt><dd id="ctx-julia-regime"><%= @state[:julia_observation_regime_hint] || 'n/a' %></dd>
            </dl>
          </article>

          <article class="panel panel-context">
            <h3>Decision Cycle (Experimental)</h3>
            <span class="badge">Experimental</span>
            <dl class="kv">
              <dt>event_count</dt><dd id="ctx-event-count"><%= Array(@state[:recent_events]).size %></dd>
              <dt>last_sync</dt><dd id="ctx-last-sync"><%= @state[:last_sync] || 'n/a' %></dd>
              <dt>note</dt><dd>Diagnostic context only, not runtime action.</dd>
            </dl>
          </article>

          <article class="panel panel-context">
            <h3>Operational Health</h3>
            <span class="badge">Context only</span>
            <dl class="kv">
              <dt>data_source</dt><dd id="ctx-data-source"><%= @data_source %></dd>
              <dt>source_type</dt><dd id="ctx-source-type"><%= @source_type %></dd>
              <dt>adapter_status</dt><dd id="ctx-adapter-status"><%= @adapter_status %></dd>
              <dt>peers_count</dt><dd id="ctx-peers-count"><%= @state[:peers_count] || 0 %></dd>
              <dt>mesh_status</dt><dd id="ctx-mesh-status"><%= @state[:mesh_status] || 'n/a' %></dd>
            </dl>
          </article>
        </div>

        <article class="panel panel-nonclaims">
          <h3>Non-claims (mandatory)</h3>
          <ul>
            <li>Not runtime authority</li>
            <li>Not global truth</li>
            <li>Not automatic sync decision</li>
          </ul>
        </article>
      </section>
    </main>

    <script src="/app.js"></script>
  </body>
</html>
